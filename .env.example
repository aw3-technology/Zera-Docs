# ─────────────────────────────────────────────────────────────
# Help Center — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Your backend API base URL (no trailing slash)
PUBLIC_API_URL=https://your-api.example.com/api

# The project / workspace ID to load content for
PUBLIC_PROJECT_ID=your-project-uuid-here

# Site metadata
PUBLIC_SITE_TITLE=Help Center
PUBLIC_SITE_DESCRIPTION=Get help and support

# Optional: set if hosting at a sub-path (e.g. /docs, /help)
# Leave blank for root deployments.
# PUBLIC_BASE_PATH=/docs

# Anthropic API key for AI Assistant (server-side only, never exposed to client)
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
