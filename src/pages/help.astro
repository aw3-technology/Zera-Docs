---
// Force server-side rendering for dynamic subdomain support
export const prerender = false;

import { getArticles, getCategories, getHelpCenterConfig, getFaqs } from '../lib/api';
import { getProjectIdFromRequest } from '../lib/projectContext';
import BaseLayout from '../layouts/BaseLayout.astro';
import HelpCenterHome from '../components/HelpCenterHome';

let projectId: string = import.meta.env.PUBLIC_PROJECT_ID || '6da7042b-22c0-4568-801c-ec608649cd19';
let articles: any[] = [];
let categories: any[] = [];
let faqs: any[] = [];
let configData: any = null;

try {
  try {
    projectId = await getProjectIdFromRequest(Astro.url.href, Astro.request);
  } catch (projectIdError) {
    console.error('[Help Page] Failed to resolve project ID:', projectIdError);
  }

  const fetchPromises = await Promise.allSettled([
    getArticles(projectId),
    getCategories(projectId),
    getFaqs(projectId),
    getHelpCenterConfig(projectId)
  ]);

  articles = fetchPromises[0].status === 'fulfilled' ? fetchPromises[0].value : [];
  categories = fetchPromises[1].status === 'fulfilled' ? fetchPromises[1].value : [];
  faqs = fetchPromises[2].status === 'fulfilled' ? fetchPromises[2].value : [];
  configData = fetchPromises[3].status === 'fulfilled' ? fetchPromises[3].value : null;
} catch (e) {
  console.error('[Help Page] Unexpected error:', e);
}

const defaultConfig = {
  portal_name: 'Help Center',
  primary_color: '#3b82f6',
  welcome_title: 'How can we help you?',
  welcome_subtitle: 'Search our knowledge base or browse categories below',
  theme_mode: 'light' as const,
  show_search: true,
  show_categories: true,
  ai_answer_enabled: false,
};

const config = configData || defaultConfig;
---

<BaseLayout 
  title={`${config.portal_name} | ${config.meta_title || 'Help Center'}`}
  description={config.meta_description || config.welcome_subtitle}
  config={config}
  projectId={projectId}
  ogImage={config.og_image_url}
  ogType="website"
>
  <HelpCenterHome
    client:only="react"
    config={config}
    articles={articles}
    categories={categories}
    faqs={faqs}
    projectId={projectId}
  />
</BaseLayout>
