---
// Force server-side rendering for dynamic subdomain support
export const prerender = false;

import { getArticles, getCategories, getHelpCenterConfig, getOpenApiSpec } from '../../lib/api';
import { getProjectIdFromRequest } from '../../lib/projectContext';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticlePageWrapper from '../../components/ArticlePageWrapper';

let projectId: string = import.meta.env.PUBLIC_PROJECT_ID || '6da7042b-22c0-4568-801c-ec608649cd19';
let allArticles: any[] = [];
let categories: any[] = [];
let folders: any[] = [];
let config: any = null;
let apiSpecUrl: string | null = null;

try {
  // Get project ID from domain/subdomain
  try {
    projectId = await getProjectIdFromRequest(Astro.url.href, Astro.request);
    console.log('[Article Page] Resolved project ID:', projectId);
  } catch (projectIdError) {
    console.error('[Article Page] Failed to resolve project ID:', projectIdError);
    // projectId already has fallback value
  }

  // Fetch all data with individual error handling
  const fetchPromises = await Promise.allSettled([
    getArticles(projectId),
    getCategories(projectId),
    getHelpCenterConfig(projectId),
    fetch(`${import.meta.env.PUBLIC_API_URL || 'https://api.usegately.com/api'}/public/projects/${projectId}/help-folders`).then(r => r.json()).then(d => d.data?.folders || d.folders || []).catch(() => []),
    getOpenApiSpec(projectId),
  ]);

  allArticles = fetchPromises[0].status === 'fulfilled' ? fetchPromises[0].value : [];
  categories = fetchPromises[1].status === 'fulfilled' ? fetchPromises[1].value : [];
  config = fetchPromises[2].status === 'fulfilled' ? fetchPromises[2].value : null;
  folders = fetchPromises[3].status === 'fulfilled' ? fetchPromises[3].value : [];
  // getOpenApiSpec returns the raw spec content — we just need to know if it exists
  // The actual URL is constructed from the public API endpoint
  const hasSpec = fetchPromises[4].status === 'fulfilled' && fetchPromises[4].value !== null;
  if (hasSpec) {
    apiSpecUrl = `${import.meta.env.PUBLIC_API_URL || 'https://api.usegately.com/api'}/public/projects/${projectId}/openapi`;
  }
  
  // Log any failures
  fetchPromises.forEach((result, index) => {
    if (result.status === 'rejected') {
      const names = ['articles', 'categories', 'config', 'folders', 'openapi'];
      console.error(`[Article Page] Failed to fetch ${names[index]}:`, result.reason);
    }
  });
} catch (e) {
  console.error('[Article Page] Unexpected error:', e);
  // Continue with empty data
}

const { slug } = Astro.params;

// Find the article by slug
const article = allArticles.find(a => a.slug === slug);

// Handle case where article is not found
if (!article) {
  return new Response(null, {
    status: 404,
    statusText: 'Not found'
  });
}

const defaultConfig = {
  portal_name: 'Help Center',
  primary_color: '#3b82f6',
  theme_mode: 'light' as const,
  sidebar_style: 'default' as const,
};

const helpCenterConfig = config || defaultConfig;

const getCategoryName = (categoryId: string | null) => {
  if (!categoryId) return 'General';
  return categories.find(c => c.id === categoryId)?.name || 'General';
};

const formattedDate = article?.created_at 
  ? new Date(article.created_at).toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric'
    })
  : new Date().toLocaleDateString('en-US', {
      month: 'long',
      day: 'numeric',
      year: 'numeric'
    });

// Extract article excerpt for SEO
const getArticleExcerpt = () => {
  if (article.excerpt) return article.excerpt;
  
  // Extract text from HTML content and truncate
  const tempDiv = typeof document !== 'undefined' ? document.createElement('div') : null;
  if (tempDiv) {
    tempDiv.innerHTML = article.content || '';
    const textContent = tempDiv.textContent || tempDiv.innerText || '';
    return textContent.slice(0, 160).trim() + (textContent.length > 160 ? '...' : '');
  }
  return article.title;
};

const articleExcerpt = getArticleExcerpt();
const categoryName = getCategoryName(article.category_id);

// Extract BlockNote JSON blocks server-side to avoid <script> tag nesting issues
// when Astro serializes props into the hydration script tag.
function extractBlocksFromContent(content: string): any[] | null {
  if (!content) return null;
  const m = content.match(/<script data-bn type="application\/json">([\s\S]*?)<\/script>/);
  if (!m) return null;
  try { return JSON.parse(m[1]); } catch { return null; }
}

const articleBlocks = extractBlocksFromContent(article.content);
// Pass a sanitized article — replace content with empty string if it has blocks
// (blocks are passed separately to avoid nested <script> tag corruption)
const safeArticle = articleBlocks
  ? { ...article, content: '' }
  : article;

// Generate LLM copy links
const articleUrl = `${Astro.url.origin}${Astro.url.pathname}`;
---

<BaseLayout 
  title={article.title}
  description={articleExcerpt}
  config={helpCenterConfig}
  projectId={projectId}
  folders={folders}
  ogImage={helpCenterConfig.og_image_url}
  ogType="article"
  article={{
    publishedTime: article.created_at,
    modifiedTime: article.updated_at,
    author: helpCenterConfig.portal_name,
    section: categoryName !== 'General' ? categoryName : undefined
  }}
>
  <!-- Article content -->
  <ArticlePageWrapper
    client:only="react"
    transition:persist="article-page-wrapper"
    config={helpCenterConfig}
    article={safeArticle}
    articleBlocks={articleBlocks}
    categories={categories}
    allArticles={allArticles}
    categoryName={categoryName}
    articleUrl={articleUrl}
    formattedDate={formattedDate}
    projectId={projectId}
    folders={folders}
    apiSpecUrl={apiSpecUrl}
  />
</BaseLayout>
