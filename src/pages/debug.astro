---
export const prerender = false;

import { resolveProjectId } from '../lib/domain';

const url = Astro.url.href;
const hostname = new URL(url).hostname;

let projectId = 'NOT_RESOLVED';
let error = null;
let logs: string[] = [];

// Capture console logs
const originalLog = console.log;
const originalError = console.error;
const capturedLogs: string[] = [];

console.log = (...args) => {
  capturedLogs.push('[LOG] ' + args.join(' '));
  originalLog(...args);
};

console.error = (...args) => {
  capturedLogs.push('[ERROR] ' + args.join(' '));
  originalError(...args);
};

try {
  projectId = await resolveProjectId(url, Astro.request);
} catch (e) {
  error = e instanceof Error ? e.message : String(e);
  capturedLogs.push('[EXCEPTION] ' + error);
}

logs = capturedLogs;

// Restore console
console.log = originalLog;
console.error = originalError;

const envProjectId = import.meta.env.PUBLIC_PROJECT_ID;
const envApiUrl = import.meta.env.PUBLIC_API_URL;
---

<!DOCTYPE html>
<html>
<head>
  <title>Debug Domain Resolution</title>
  <style>
    body { font-family: monospace; padding: 20px; background: #1a1a1a; color: #fff; }
    .section { margin: 20px 0; padding: 15px; background: #2a2a2a; border-radius: 5px; }
    .label { color: #888; }
    .value { color: #4af; }
    .error { color: #f44; }
    .success { color: #4f4; }
    pre { background: #000; padding: 10px; overflow-x: auto; }
  </style>
</head>
<body>
  <h1>Domain Resolution Debug</h1>
  
  <div class="section">
    <h2>Request Info</h2>
    <div><span class="label">URL:</span> <span class="value">{url}</span></div>
    <div><span class="label">Hostname:</span> <span class="value">{hostname}</span></div>
  </div>

  <div class="section">
    <h2>Environment Variables</h2>
    <div><span class="label">PUBLIC_API_URL:</span> <span class="value">{envApiUrl || 'NOT SET'}</span></div>
    <div><span class="label">PUBLIC_PROJECT_ID:</span> <span class="value">{envProjectId || 'NOT SET'}</span></div>
  </div>

  <div class="section">
    <h2>Resolution Result</h2>
    <div><span class="label">Project ID:</span> <span class={projectId === envProjectId ? 'error' : 'success'}>{projectId}</span></div>
    {error && <div><span class="label">Error:</span> <span class="error">{error}</span></div>}
    {projectId === envProjectId && <div class="error">⚠️ Using fallback env variable instead of resolving from domain!</div>}
    {projectId !== envProjectId && projectId !== 'NOT_RESOLVED' && <div class="success">✓ Successfully resolved from domain!</div>}
  </div>

  <div class="section">
    <h2>Console Logs</h2>
    <pre>{logs.join('\n')}</pre>
  </div>

  <div class="section">
    <h2>Test API Calls</h2>
    <button onclick="testResolve()">Test Resolve Domain API</button>
    <button onclick="testBySlug()">Test By-Slug API</button>
    <pre id="apiResult"></pre>
  </div>

  <script>
    async function testResolve() {
      const hostname = window.location.hostname;
      const result = document.getElementById('apiResult');
      if (!result) return;
      result.textContent = 'Testing...';
      
      try {
        const response = await fetch(`/api/public/help-center/resolve-domain?domain=${hostname}`);
        const data = await response.json();
        result.textContent = `Status: ${response.status}\n${JSON.stringify(data, null, 2)}`;
      } catch (e) {
        result.textContent = `Error: ${e instanceof Error ? e.message : String(e)}`;
      }
    }

    async function testBySlug() {
      const hostname = window.location.hostname;
      const subdomain = hostname.replace('.usegately.com', '');
      const result = document.getElementById('apiResult');
      if (!result) return;
      result.textContent = 'Testing...';
      
      try {
        const response = await fetch(`/api/public/projects/by-slug/${subdomain}`);
        const data = await response.json();
        result.textContent = `Status: ${response.status}\n${JSON.stringify(data, null, 2)}`;
      } catch (e) {
        result.textContent = `Error: ${e instanceof Error ? e.message : String(e)}`;
      }
    }

    // Expose functions to window for onclick handlers
    (window as any).testResolve = testResolve;
    (window as any).testBySlug = testBySlug;
  </script>
</body>
</html>
